{
    "manifest_version": 3,
    "name": "bm-extra",
    "version": "1.2.12",
    "description": "BattleMetrics Extension that aims to enhance your experience with quality of life features.",
    "author": "FlQyD | panadodev",
    "content_scripts": [
        {
            "matches": [
                "https://www.battlemetrics.com/*"
            ],
            "run_at": "document_start",
            "js": [
                "./main.js"
            ],
            "css": [
                "./assets/style/main.css",
                "./assets/style/settings.css",
                "./assets/style/sidebar.css"
            ]
        }
    ],
    "background": {
        "service_worker": "bg/bg.js",
        "type": "module"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "assets/img/*.png",
                "modules/*.js"
            ],
            "matches": [
                "*://www.battlemetrics.com/*",
                "*://battlemetrics.com/*"
            ]
        }
    ],
    "host_permissions": [
        "*://api.battlemetrics.com/*",
        "*://api.steampowered.com/*",
        "*://api.panado.dev/get-teaminfo/*",
        "*://rust-api.facepunch.com/*",
        "*://proxycheck.io/*"
    ],
    "permissions": [
        "downloads"
    ]
}